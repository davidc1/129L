
# built-in exceptions in python
#https://docs.python.org/3/library/exceptions.html

def CONVERT_TO_FLOAT(val):
    try:
        return float(val)
    except ValueError:
        print("Value Error: could not convert to float")

def _FACTORIAL(val):

    if (val == 1):
        return 1
    
    return val * factorial(val-1)

def factorial(val):

    if (val <= 0):
        raise ValueError("Input negative -> EXIt")

    if (int(val) != val):
        raise ValueError("Input not an integer -> EXIT")

    return _FACTORIAL(val)

def factorial_check(val):

    try:
        factorial(val)
    except ValueError as e:
        print("caught error ",e)

    return 0
